<!DOCTYPE html>
<html lang="az">
  <%- include("partials/head") %>
  <body class="bg-[#0c0d12] text-white">
    <div class="shell min-h-screen antialiased flex flex-col">
      <%- include("partials/navbar", { siteData }) %>

      <main class="flex-1 pt-32 pb-20 px-4">
        <div class="container mx-auto max-w-5xl">
          <header class="mb-12" data-aos="fade-down">
            <h1 class="text-4xl lg:text-6xl font-black uppercase tracking-tighter">Səbətim</h1>
            <p class="text-white/40 font-bold uppercase tracking-widest mt-2 flex items-center gap-2">
              <span class="w-8 h-px bg-white/20"></span>
              Alış-verişə davam etmək üçün hazırsınız?
            </p>
          </header>

          <div class="grid lg:grid-cols-3 gap-12">
            <!-- Left: Items List -->
            <div class="lg:col-span-2 space-y-6" data-aos="fade-right">
              <div id="cart-items-list" class="space-y-4">
                <!-- Injected by JS -->
                <div class="flex flex-col items-center justify-center py-20 bg-white/[0.02] border-2 border-dashed border-white/5 rounded-[40px]">
                   <div class="w-16 h-16 border-4 border-primary/20 border-t-primary rounded-full animate-spin mb-4"></div>
                   <p class="text-white/20 font-black uppercase tracking-widest text-xs">Yüklənir...</p>
                </div>
              </div>
            </div>

            <!-- Right: Order Summary -->
            <div class="lg:col-span-1" data-aos="fade-left">
              <div class="sticky top-32 bg-white/[0.02] border border-white/10 rounded-[40px] p-8 space-y-8">
                <h3 class="text-xl font-black uppercase tracking-tight">Sifariş özəti</h3>
                
                <div class="space-y-4">
                  <div class="flex justify-between items-center text-sm font-bold">
                    <span class="text-white/40 uppercase">Məhsulun qiyməti</span>
                    <span class="text-white subtotal-val" id="cart-subtotal">0.00 ₼</span>
                  </div>
                  <div class="flex justify-between items-center text-sm font-bold">
                    <span class="text-white/40 uppercase">ƏDV (18%)</span>
                    <span class="text-white tax-val" id="cart-tax">0.00 ₼</span>
                  </div>
                  <div class="pt-6 border-t border-white/5 flex justify-between items-end">
                    <div>
                      <span class="block text-xs font-black text-white/20 uppercase tracking-widest mb-1">Yekun Məbləğ</span>
                      <span class="text-3xl font-black text-primary tracking-tighter total-val" id="cart-total">0.00 ₼</span>
                    </div>
                  </div>
                </div>

                <div id="cart-footer" hidden>
                  <button class="checkout-btn w-full bg-primary hover:bg-primary/90 text-white h-16 rounded-2xl font-black uppercase tracking-widest text-sm flex items-center justify-center gap-4 transition-all hover:scale-[1.02] active:scale-95 shadow-xl shadow-primary/20 group" type="button">
                    <iconify-icon icon="lucide:check-circle" class="text-2xl group-hover:rotate-12 transition-transform"></iconify-icon>
                    Sifarişi tamamla
                  </button>
                </div>

                <p class="text-[10px] text-white/20 font-bold uppercase text-center leading-relaxed">
                  Ödəniş edərək <a href="#" class="text-white/40 hover:text-white underline">İstifadə Şərtlərini</a> qəbul etmiş olursunuz.
                </p>
              </div>
            </div>
          </div>
        </div>
      </main>

      <%- include("partials/footer", { siteData }) %>

      <div class="toast-container" id="toast-container"></div>
      
      <!-- Shared Overlays for Logic Compatibility -->
      <div id="search-overlay" hidden></div>
      <div id="mobile-menu-overlay" class="hidden"></div>
    </div>

    <script id="site-data" type="application/json"><%- JSON.stringify(siteData).replace(/</g, "\\u003c") %></script>
    <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.10.3/sql-wasm.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"></script>
    <script type="module" src="/js/app.js"></script>
    <script>
      AOS.init({ duration: 800, once: true });
    </script>
  </body>
</html>
