<%- include("partials/head", { title }) %>
<%- include("partials/sidebar", { active }) %>

<div class="content-wrapper">
  <section class="content-header">
    <div class="container-fluid">
      <h1>Satışların İdarə Edilməsi</h1>
    </div>
  </section>

  <section class="content">
    <div class="container-fluid">
      <div class="card shadow-sm border-0">
        <div class="card-header"><h3 class="card-title">Sifarişlərin Siyahısı</h3></div>
        <div class="card-body table-responsive p-0">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Kod</th>
                <th>Müştəri</th>
                <th>Məhsul / Miqdar</th>
                <th>Məbləğ</th>
                <th>Status</th>
                <th>Tarix</th>
                <th>Əməliyyatlar</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach((order) => { %>
                <tr>
                  <td><strong><%= order.order_code %></strong></td>
                  <td>
                    <div class="d-flex flex-column">
                      <span><%= order.customer_name %></span>
                      <small class="text-muted"><%= order.customer_email %></small>
                    </div>
                  </td>
                  <td>
                    <span><%= order.product_title %></span><br>
                    <small class="badge badge-light border"><%= order.item_count %> ədəd</small>
                  </td>
                  <td><span class="font-weight-bold"><%= order.total_amount.toFixed(2) %> AZN</span></td>
                  <td>
                    <div class="d-flex flex-column gap-1">
                      <span class="badge <%= order.payment_status === 'approved' ? 'bg-success' : (order.payment_status === 'rejected' ? 'bg-danger' : 'bg-warning') %> mb-1">
                        <%= order.payment_status === 'approved' ? 'Ödənilib' : (order.payment_status === 'rejected' ? 'Rədd edilib' : 'Gözləmədə') %>
                      </span>
                      <span class="badge <%= order.delivery_status === 'delivered' ? 'bg-light border text-dark' : 'bg-light border' %>">
                        <%= order.delivery_status === 'delivered' ? 'Çatdırılıb' : 'Hazırlanır' %>
                      </span>
                    </div>
                  </td>
                  <td><small><%= new Date(order.created_at).toLocaleString('az-AZ') %></small></td>
                  <td>
                    <div class="btn-group">
                      <% if (order.payment_status === 'pending') { %>
                        <form action="/admin/sales/<%= order.id %>/approve" method="POST" class="d-inline" onsubmit="return confirm('Ödənişi təsdiqləmək istəyirsiniz?')">
                          <button type="submit" class="btn btn-sm btn-success mr-2" title="Təsdiqlə">
                            <i class="fas fa-check"></i>
                          </button>
                        </form>
                      <% } %>
                      <% if (order.payment_proof) { %>
                        <a href="<%= order.payment_proof %>" target="_blank" class="btn btn-sm btn-info" title="Çekə bax">
                          <i class="fas fa-receipt"></i>
                        </a>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
              <% if (orders.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center py-5 text-muted">
                    <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                    Hələ heç bir sifariş yoxdur.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</div>

<%- include("partials/footer") %>
