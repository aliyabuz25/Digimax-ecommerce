<div class="contact-root">
  <div class="sketch-decor decor-1"></div>
  <div class="sketch-decor decor-2"></div>
  <div class="sketch-decor decor-3"></div>
  <div class="sketch-decor decor-4"></div>

  <div class="contact-container mx-auto max-w-[1280px]">
    <div class="contact-grid">
      <div class="contact-form-side" data-aos="fade-right">
        <div class="section-badge">Əlaqə Saxla</div>
        <h2 class="section-title">Bizə bir mesaj <span class="sketch-highlight">göndər</span></h2>
        <p class="section-desc">Hər hansı bir sualınız və ya təklifiniz varsa, bizimlə əlaqə saxlamaqdan çəkinməyin.</p>

        <form id="contact-form" class="main-form">
          <div class="form-row">
            <div class="input-group">
              <label for="contact-name">Adınız</label>
              <input id="contact-name" name="name" type="text" placeholder="Məhəmməd Əliyev" required />
            </div>
            <div class="input-group">
              <label for="contact-email">E-poçt</label>
              <input id="contact-email" name="email" type="email" placeholder="ali@example.com" required />
            </div>
          </div>
          <div class="input-group">
            <label for="contact-subject">Mövzu</label>
            <input id="contact-subject" name="subject" type="text" placeholder="Sifariş haqqında" />
          </div>
          <div class="input-group">
            <label for="contact-message">Mesajınız</label>
            <textarea id="contact-message" name="message" placeholder="Mesajınızı buraya yazın..." rows="5"></textarea>
          </div>

          <button id="contact-submit-btn" type="submit" class="submit-btn btn-sketch">Mesajı Göndər</button>
        </form>
      </div>

      <div class="contact-info-side" data-aos="fade-left">
        <div class="info-card">
          <div class="info-item">
            <div class="info-icon"><iconify-icon icon="solar:map-point-bold-duotone"></iconify-icon></div>
            <div class="info-text">
              <h4>Ünvanımız</h4>
              <p>Bakı şəhəri, Nizami küç. 102, Azərbaycan</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon"><iconify-icon icon="solar:phone-bold-duotone"></iconify-icon></div>
            <div class="info-text">
              <h4>Əlaqə nömrəsi</h4>
              <p>+994 (55) 123 45 67</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon"><iconify-icon icon="solar:letter-bold-duotone"></iconify-icon></div>
            <div class="info-text">
              <h4>E-poçt</h4>
              <p>info@digimax.az</p>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon"><iconify-icon icon="solar:clock-circle-bold-duotone"></iconify-icon></div>
            <div class="info-text">
              <h4>İş saatları</h4>
              <p>B.e. - Şənbə: 10:00 - 20:00</p>
            </div>
          </div>
        </div>

        <div class="map-wrapper">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12157.06059955365!2d49.85244569345719!3d40.37503022510344!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40307d077c61fef3%3A0xfa91a337fe6f0db5!2sNizami%20Street%2C%20Bak%C4%B1!5e0!3m2!1sen!2saz!4v1700000000000!5m2!1sen!2saz"
            width="100%"
            height="250"
            style="border:0;"
            loading="lazy"
            class="google-map"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</div>
