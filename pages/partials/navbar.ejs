<header class="fixed top-0 left-0 w-full z-[100] transition-all duration-300 border-b border-white/5 bg-[#0c0d12]/60 backdrop-blur-xl" id="site-header">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="h-20 lg:h-24 flex items-center justify-between gap-8">
      <!-- Left: Logo & Menu -->
      <div class="flex items-center gap-12">
        <a href="/" class="flex-shrink-0" data-nav-action="home">
          <img src="/digimax_app_logo_icon.png" alt="Digimax" class="h-10 lg:h-12 w-auto transition-transform hover:scale-110 active:scale-95" />
        </a>

        <nav class="hidden lg:block">
          <ul class="flex items-center gap-2">
            <% siteData.navigation.forEach((item) => { %>
              <li class="relative group cursor-pointer px-4 py-2 rounded-xl transition-all hover:bg-white/5 flex items-center gap-3 active:scale-95" data-nav-action="<%= item.action %>">
                <span class="text-xl text-white/50 group-hover:text-primary transition-colors flex items-center">
                  <% if (item.icon && (item.icon.includes('lucide:') || item.icon.includes('solar:'))) { %>
                    <iconify-icon icon="<%= item.icon %>"></iconify-icon>
                  <% } else if (item.icon && item.icon.startsWith('<')) { %>
                    <%- item.icon %>
                  <% } else if (item.icon) { %>
                    <iconify-icon icon="<%= item.icon %>"></iconify-icon>
                  <% } %>
                </span>
                <span class="text-sm font-bold tracking-tight text-white/70 group-hover:text-white transition-colors uppercase"><%= item.label %></span>
                <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-primary to-secondary rounded-full transition-all group-hover:w-full"></div>
              </li>
            <% }) %>
          </ul>
        </nav>
      </div>

      <!-- Right: Search, Auth, Cart -->
      <div class="flex items-center gap-3 lg:gap-4">
        <!-- Search -->
        <button class="hidden lg:flex w-10 h-10 items-center justify-center rounded-xl bg-white/5 border border-white/5 text-white/60 hover:text-white hover:bg-white/10 hover:border-white/20 transition-all active:scale-95" id="search-open-btn" aria-label="Search" type="button">
          <iconify-icon icon="lucide:search" class="text-xl"></iconify-icon>
        </button>

        <!-- User/Auth -->
        <div class="hidden lg:block relative">
          <% if (user) { %>
            <div class="flex items-center gap-4 pl-4 pr-1 py-1 rounded-2xl bg-white/5 border border-white/5 hover:border-white/20 transition-all group">
              <span class="text-sm font-black text-white/90 tracking-tighter"><%= Number(user.balance || 0).toFixed(2) %> ₼</span>
              <a href="<%= user.role === 'admin' ? '/admin' : '/profile' %>" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/10 text-white transition-all group-hover:bg-primary active:scale-95 relative" aria-label="Profile">
                <iconify-icon icon="lucide:user" class="text-xl"></iconify-icon>
                <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-[#0c0d12] <%= user.role === 'admin' ? 'bg-amber-400 animate-pulse' : 'bg-green-500' %>"></div>
              </a>
            </div>
          <% } else { %>
            <a href="/login" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/5 text-white/60 hover:text-white hover:bg-white/10 hover:border-white/20 transition-all active:scale-95" aria-label="Login">
              <iconify-icon icon="lucide:user" class="text-xl"></iconify-icon>
            </a>
          <% } %>
        </div>

        <!-- Cart -->
        <div class="relative group">
          <a href="/cart" id="main-cart-icon" class="w-10 h-10 lg:w-12 lg:h-12 flex items-center justify-center rounded-xl lg:rounded-2xl bg-primary text-white shadow-lg shadow-primary/20 hover:scale-105 active:scale-90 transition-all cursor-pointer" aria-label="Cart">
            <iconify-icon icon="lucide:shopping-cart" class="text-xl lg:text-2xl"></iconify-icon>
            <span class="absolute -top-2 -right-2 min-w-[22px] h-[22px] px-1.5 flex items-center justify-center rounded-full bg-white text-primary text-[10px] font-black border-2 border-primary group-hover:scale-110 transition-transform" id="cart-badge" hidden>0</span>
          </a>
        </div>

        <!-- Mobile Menu Toggle -->
        <button class="lg:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 text-white/70 active:scale-90 transition-all" id="mobile-menu-open-btn" type="button" aria-label="Menu">
          <iconify-icon icon="lucide:menu" class="text-2xl"></iconify-icon>
        </button>
      </div>
    </div>
  </div>
</header>
