<!DOCTYPE html>
<html lang="az">
  <%- include("partials/head") %>
  <body>
    <div class="shell min-h-screen antialiased">
      <div id="product-modal-root"></div>

      <div id="app-splash" class="app-splash">
        <div class="splash-inner">
          <div class="splash-loader-bar">
            <div class="splash-loader-fill"></div>
          </div>
        </div>
      </div>

      <div id="app-content" class="app-main-content" hidden>
        <%- include("partials/navbar", { siteData }) %>

        <main class="page-content">
          <div id="contact-view" class="contact-view" hidden>
            <%- include("partials/contact-section") %>
          </div>

          <div id="store-view" class="store-view">
            <%- include("partials/catalog-view", { siteData }) %>
            <%- include("partials/home-view", { siteData }) %>
          </div>
        </main>

        <%- include("partials/footer", { siteData }) %>
      </div>

      <div class="flying-container" id="flying-container"></div>
      <div class="toast-container" id="toast-container"></div>

      <!-- Search Overlay -->
      <div id="search-overlay" class="fixed inset-0 z-[200] bg-[#0c0d12]/90 backdrop-blur-2xl px-6 py-20 flex flex-col items-center transition-all duration-500 opacity-0 pointer-events-none data-[active=true]:opacity-100 data-[active=true]:pointer-events-auto" hidden>
        <div class="w-full max-w-2xl relative">
          <input id="search-input" type="text" placeholder="Hansı oyunu axtarırsınız?" class="w-full bg-transparent border-0 border-b-2 border-white/10 py-6 text-3xl lg:text-5xl font-black text-white placeholder:text-white/10 focus:ring-0 focus:border-primary transition-all uppercase tracking-tighter" autocomplete="off" />
          <div id="search-loader" class="absolute right-0 top-1/2 -translate-y-1/2" hidden>
            <div class="w-8 h-8 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
          </div>
        </div>

        <button class="absolute top-8 right-8 text-white/40 hover:text-white transition-colors p-4" id="search-close-btn" type="button">
          <iconify-icon icon="solar:close-circle-bold-duotone" class="text-5xl"></iconify-icon>
        </button>

        <div id="search-results-container" class="w-full max-w-2xl mt-12 overflow-y-auto pr-2 custom-scrollbar flex-1"></div>
      </div>

      <!-- Cart Modal -->
      <div id="cart-overlay" class="fixed inset-0 z-[200] bg-black/60 backdrop-blur-md flex items-center justify-center p-4 transition-all duration-500 opacity-0 pointer-events-none data-[active=true]:opacity-100 data-[active=true]:pointer-events-auto" hidden>
        <div class="cart-drawer w-full max-w-lg bg-[#13141c] border border-white/10 rounded-[32px] overflow-hidden shadow-2xl flex flex-col max-h-[85vh] scale-95 transition-transform duration-500 data-[active=true]:scale-100">
          <div class="px-8 py-6 border-b border-white/5 flex items-center justify-between bg-white/[0.02]">
            <div>
              <h3 class="text-xl font-black text-white uppercase tracking-tight">Səbətim</h3>
              <p class="text-xs text-white/40 font-bold uppercase mt-0.5">Səbətinizdəki məhsullar</p>
            </div>
            <button class="w-10 h-10 rounded-full bg-white/5 text-white/40 hover:bg-white/10 hover:text-white transition-all flex items-center justify-center text-2xl" id="cart-close-btn" type="button">×</button>
          </div>

          <div class="flex-1 overflow-y-auto px-8 py-6 custom-scrollbar space-y-4" id="cart-items-list">
            <!-- Items injected by JS -->
          </div>

          <div id="cart-footer" class="px-8 py-8 bg-white/[0.02] border-t border-white/5 space-y-6" hidden>
            <div class="space-y-2">
              <div class="flex justify-between text-sm font-bold"><span class="text-white/40 uppercase">Cəmi:</span><span class="text-white" id="cart-subtotal"></span></div>
              <div class="flex justify-between text-sm font-bold"><span class="text-white/40 uppercase">ƏDV (18%):</span><span class="text-white" id="cart-tax"></span></div>
              <div class="flex justify-between text-xl font-black pt-4 border-t border-white/5 mt-4"><span class="text-white uppercase tracking-tight">Yekun:</span><span class="text-primary" id="cart-total"></span></div>
            </div>
            <button class="checkout-btn w-full bg-primary hover:bg-primary/90 text-white h-14 rounded-2xl font-black uppercase tracking-widest text-sm flex items-center justify-center gap-3 transition-all hover:scale-[1.02] active:scale-95 shadow-lg shadow-primary/20" type="button">
              <iconify-icon icon="lucide:check-circle" class="text-xl"></iconify-icon>
              Ödənişə keç
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Overlay -->
      <div id="mobile-menu-overlay" class="fixed inset-0 z-[200] bg-[#0c0d12] flex flex-col transition-transform duration-500 translate-x-full data-[active=true]:translate-x-0" hidden>
        <div class="px-6 h-20 flex items-center justify-between border-b border-white/5 bg-white/[0.01]">
          <img src="/digimax_app_logo_icon.png" class="h-8 w-auto" alt="Digimax" />
          <button class="w-10 h-10 rounded-xl bg-white/5 text-white flex items-center justify-center text-2xl" id="mobile-menu-close-btn" type="button">×</button>
        </div>

        <div class="flex-1 overflow-y-auto py-8">
          <ul class="space-y-2 px-4">
            <% siteData.navigation.forEach((item) => { %>
              <li>
                <button class="w-full flex items-center gap-4 px-6 py-4 rounded-2xl bg-white/[0.02] border border-white/5 text-white/70 active:bg-primary active:text-white transition-all group" type="button" data-nav-action="<%= item.action %>">
                  <span class="text-2xl text-primary flex items-center">
                    <% if (item.icon && (item.icon.includes('lucide:') || item.icon.includes('solar:'))) { %>
                      <iconify-icon icon="<%= item.icon %>"></iconify-icon>
                    <% } else if (item.icon && item.icon.startsWith('<')) { %>
                      <%- item.icon %>
                    <% } else if (item.icon) { %>
                      <iconify-icon icon="<%= item.icon %>"></iconify-icon>
                    <% } %>
                  </span>
                  <span class="text-lg font-black uppercase tracking-tight"><%= item.label %></span>
                </button>
              </li>
            <% }) %>
          </ul>
        </div>

        <div class="p-6 border-t border-white/5 bg-white/[0.01]">
          <a href="/cart" class="w-full h-16 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center gap-4 text-white font-black uppercase tracking-widest relative overflow-hidden" id="mobile-cart-btn">
            <iconify-icon icon="solar:cart-large-minimalistic-bold" class="text-2xl text-primary"></iconify-icon>
            <span id="mobile-cart-count">Səbət (0)</span>
          </a>
        </div>
      </div>

    </div>

    <script id="site-data" type="application/json"><%- JSON.stringify(siteData).replace(/</g, "\\u003c") %></script>
    <script>
      (() => {
        const siteDataNode = document.getElementById("site-data");

        if (siteDataNode) {
          try {
            window.__SITE_DATA__ = JSON.parse(siteDataNode.textContent || "{}");
          } catch (error) {
            console.error("Failed to parse site data.", error);
            window.__SITE_DATA__ = {};
          }
        }

        window.setTimeout(() => {
          const splash = document.getElementById("app-splash");
          const content = document.getElementById("app-content");
          if (splash) {
            splash.style.transition = "opacity 0.5s ease";
            splash.style.opacity = "0";
            setTimeout(() => splash.remove(), 500);
          }
          if (content) {
            content.style.display = "block";
            content.hidden = false;
          }
        }, 3500);
      })();
    </script>
    <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.10.3/sql-wasm.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.3.0/flowbite.min.js"></script>
    <script type="module" src="/js/app.js"></script>
  </body>
</html>
