<!DOCTYPE html>
<html lang="az">
<%- include("partials/head") %>
<body>
  <div class="shell min-h-screen antialiased">
    <%- include("partials/navbar", { siteData }) %>

    <main class="profile-page py-20 px-4">
      <div class="container mx-auto max-w-4xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Sidebar -->
          <div class="md:col-span-1 space-y-6">
            <div class="profile-card bg-[#1c202c] border border-[#2a2f3b] p-8 rounded-3xl text-center">
              <div class="w-24 h-24 bg-purple-600 rounded-full mx-auto flex items-center justify-center text-3xl font-bold mb-4 shadow-xl shadow-purple-500/20">
                <%= user.name.charAt(0) %>
              </div>
              <h2 class="text-xl font-bold"><%= user.name %></h2>
              <p class="text-sm text-gray-400 mb-6"><%= user.email %></p>
              <div class="balance-badge bg-green-500/10 text-green-400 py-2 px-4 rounded-full text-sm font-bold border border-green-500/20">
                Balans: <%= user.balance ? user.balance.toFixed(2) : '0.00' %> AZN
              </div>
            </div>
            
            <nav class="bg-[#1c202c] border border-[#2a2f3b] rounded-3xl overflow-hidden">
              <a href="/profile" class="block py-4 px-6 text-gray-400 hover:bg-[#161a25] transition-all">Sifarişlərim</a>
              <a href="/profile/edit" class="block py-4 px-6 bg-purple-600 text-white font-medium border-l-4 border-white transition-all">Məlumatlarım</a>
              <a href="/logout" class="block py-4 px-6 text-red-400 hover:bg-red-400/5 transition-all">Çıxış</a>
            </nav>
          </div>

          <!-- Content -->
          <div class="md:col-span-2">
            <div class="content-card bg-[#1c202c] border border-[#2a2f3b] p-8 rounded-3xl min-h-[400px]">
              <h1 class="text-2xl font-bold mb-8">Məlumatlarım</h1>
              
              <% if (typeof success !== 'undefined' && success) { %>
                <div class="bg-green-500/10 border border-green-500/20 text-green-400 p-4 rounded-xl mb-6">
                  Məlumatlarınız uğurla yeniləndi.
                </div>
              <% } %>
              
              <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl mb-6">
                  <%= error %>
                </div>
              <% } %>

              <form action="/profile/edit" method="POST" class="space-y-6">
                <!-- Name -->
                <div>
                  <label class="block text-sm font-medium text-gray-400 mb-2">Ad Soyad</label>
                  <input type="text" name="name" value="<%= user.name %>" required class="w-full bg-[#161a25] border border-[#2a2f3b] text-white rounded-xl p-4 focus:ring-2 focus:ring-purple-600 focus:border-transparent outline-none transition-all">
                </div>

                <!-- Email -->
                <div>
                  <label class="block text-sm font-medium text-gray-400 mb-2">Email Ünvanı</label>
                  <input type="email" name="email" value="<%= user.email %>" required class="w-full bg-[#161a25] border border-[#2a2f3b] text-white rounded-xl p-4 focus:ring-2 focus:ring-purple-600 focus:border-transparent outline-none transition-all">
                </div>
                
                <!-- GSM -->
                <div>
                  <label class="block text-sm font-medium text-gray-400 mb-2">GSM (Telefon)</label>
                  <input type="tel" name="gsm" value="<%= user.gsm || '' %>" class="w-full bg-[#161a25] border border-[#2a2f3b] text-white rounded-xl p-4 focus:ring-2 focus:ring-purple-600 focus:border-transparent outline-none transition-all" placeholder="+994 -- --- -- --">
                </div>

                <!-- New Password (Optional) -->
                <div>
                  <label class="block text-sm font-medium text-gray-400 mb-2">Yeni Şifrə (Dəyişmək istəmirsinizsə boş saxlayın)</label>
                  <input type="password" name="password" class="w-full bg-[#161a25] border border-[#2a2f3b] text-white rounded-xl p-4 focus:ring-2 focus:ring-purple-600 focus:border-transparent outline-none transition-all" placeholder="••••••••">
                </div>

                <div class="pt-4">
                  <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-4 rounded-xl transition-all hover:shadow-lg hover:shadow-purple-600/20 active:scale-[0.98]">
                    Yadda Saxla
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
      <div class="custom-cursor-wrapper">
        <div class="cursor-dot" id="cursor-dot"></div>
        <div class="cursor-trail" id="cursor-trail"></div>
      </div>
    </main>

    <%- include("partials/footer", { siteData }) %>
  </div>

  <script id="site-data" type="application/json"><%- JSON.stringify(siteData).replace(/</g, "\\u003c") %></script>
  <script src="https://code.iconify.design/iconify-icon/3.0.0/iconify-icon.min.js"></script>
  <script type="module" src="/js/app.js"></script>
</body>
</html>
