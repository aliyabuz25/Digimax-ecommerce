<script setup>
import { computed, onBeforeUnmount, onMounted, ref } from "vue";
import { mapProductRow, queryStoreRows } from "../lib/storeDb";

defineProps({
  activePrimaryTab: {
    type: String,
    default: "",
  },
});

const emit = defineEmits(["go-home", "select-primary"]);

const mobileOpen = ref(false);
const languageOpen = ref(false);
const subMenuOpen = ref(false);
const cartOpen = ref(false);
const searchOpen = ref(false);
const searchQuery = ref("");
const isScrolled = ref(false);
const navReady = ref(false);
const cartItems = ref([]);

const handleScroll = () => {
  isScrolled.value = window.scrollY > 40;
};

const primaryLinks = ref([
  { 
    label: "PlayStation", 
    icon: `<svg width="19" height="15" viewBox="0 0 19 15" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M18.8316 11.4803C18.4603 11.9594 17.5509 12.3009 17.5509 12.3009L10.7868 14.7865V12.9529L15.7649 11.1379C16.3297 10.9315 16.416 10.6385 15.9574 10.485C15.4989 10.3315 14.6689 10.3747 14.1032 10.5829L10.7868 11.7776V9.87618L10.9777 9.80912C10.9777 9.80912 11.9363 9.46235 13.2836 9.30971C14.6318 9.15794 16.2822 9.33088 17.5776 9.83294C19.0372 10.305 19.2013 11.0012 18.8316 11.4803ZM11.4302 8.35853V3.67235C11.4302 3.12176 11.3309 2.61529 10.8257 2.47235C10.4397 2.34529 10.1996 2.71235 10.1996 3.26206V15L7.10514 13.995V0C8.42046 0.249706 10.3377 0.840882 11.3681 1.19559C13.9892 2.11588 14.8779 3.26206 14.8779 5.84294C14.8779 8.35853 13.3596 9.31147 11.4302 8.35853ZM1.42671 12.7624C-0.072566 12.33 -0.322158 11.43 0.360981 10.9121C0.992301 10.4338 2.06667 10.0738 2.06667 10.0738L6.50405 8.45912V10.2997L3.31031 11.4688C2.74635 11.6753 2.65999 11.9682 3.11772 12.1218C3.57717 12.2762 4.40713 12.2321 4.97195 12.0247L6.50405 11.4565V13.1021L6.19832 13.155C4.66622 13.4109 3.03481 13.3041 1.42671 12.7624Z"/></svg>` 
  },
  { 
    label: "Xbox", 
    icon: `<svg width="15" height="15" viewBox="0 0 15 15" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M2.56501 13.146C3.93002 14.3432 5.68435 15.0023 7.5 15C9.31681 15.0025 11.0724 14.3435 12.4387 13.146C13.6117 11.9505 9.741 7.7025 7.5 6.00975C5.26125 7.7025 1.38751 11.9505 2.56351 13.146M9.5385 4.14225C11.1007 5.9925 14.2155 10.5877 13.3357 12.2122C14.4153 10.8799 15.003 9.21632 15 7.5015C15.0013 6.50862 14.8046 5.52545 14.4215 4.60946C14.0384 3.69348 13.4765 2.86306 12.7687 2.16675C12.7687 2.16675 12.7515 2.15325 12.7177 2.1405C12.6613 2.12109 12.6019 2.11145 12.5422 2.112C12.1717 2.112 11.301 2.38425 9.5385 4.14225ZM2.28376 2.14125C2.24776 2.154 2.23276 2.16675 2.22976 2.1675C1.52224 2.86393 0.96065 3.69441 0.577801 4.61039C0.194952 5.52637 -0.0014729 6.50948 8.31521e-06 7.50225C8.31521e-06 9.2865 0.624008 10.923 1.66276 12.2107C0.788257 10.5825 3.90075 5.991 5.46375 4.14225C3.70125 2.3835 2.829 2.1135 2.46001 2.1135C2.40014 2.11147 2.34048 2.12142 2.28451 2.14275L2.28376 2.14125ZM7.5 2.21925C7.5 2.21925 5.6595 1.14225 4.2225 1.09125C3.65775 1.071 3.31275 1.27575 3.2715 1.30275C4.6125 0.40425 6.0375 0 7.491 0H7.5C8.95875 0 10.3785 0.4035 11.7285 1.30275C11.6865 1.27425 11.3445 1.07025 10.779 1.09125C9.34125 1.14225 7.5 2.21625 7.5 2.21625V2.21925Z"/></svg>`
  },
  { 
    label: "Servislər", 
    icon: `<svg width="13" height="14" viewBox="0 0 13 14" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M2.52778 0H10.4722C10.5843 0 10.6949 0.0253015 10.7952 0.0739009C10.8955 0.1225 10.9827 0.193063 11.05 0.28L13 2.8V13.3C13 13.4857 12.9239 13.6637 12.7885 13.795C12.653 13.9263 12.4693 14 12.2778 14H0.722222C0.530677 14 0.346977 13.9263 0.211534 13.795C0.076091 13.6637 0 13.4857 0 13.3V2.8L1.95 0.28C2.01727 0.193063 2.10451 0.1225 2.20479 0.0739009C2.30507 0.0253015 2.41566 0 2.52778 0ZM11.1944 2.8L10.1111 1.4H2.88889L1.80556 2.8H11.1944ZM4.33333 5.6H2.88889V7C2.88889 7.92826 3.26934 8.8185 3.94656 9.47487C4.62377 10.1313 5.54227 10.5 6.5 10.5C7.45773 10.5 8.37623 10.1313 9.05344 9.47487C9.73066 8.8185 10.1111 7.92826 10.1111 7V5.6H8.66667V7C8.66667 7.55695 8.43839 8.0911 8.03206 8.48492C7.62574 8.87875 7.07464 9.1 6.5 9.1C5.92536 9.1 5.37426 8.87875 4.96794 8.48492C4.56161 8.0911 4.33333 7.55695 4.33333 7V5.6Z"/></svg>`
  },
  { 
    label: "Oyun Valyutası", 
    icon: `<svg width="14" height="14" viewBox="0 0 401.601 401.6" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M116.682,229.329c11.286,0,22.195-0.729,32.518-2.086V114.094c-10.322-1.356-21.232-2.085-32.518-2.085 c-64.441,0-116.681,23.693-116.681,52.921v11.477C0.001,205.634,52.241,229.329,116.682,229.329z"/><path d="M116.682,288.411c11.286,0,22.195-0.729,32.518-2.084v-33.166c-10.325,1.356-21.229,2.095-32.518,2.095 c-56.25,0-103.199-18.054-114.227-42.082c-1.606,3.5-2.454,7.124-2.454,10.839v11.477 C0.001,264.718,52.241,288.411,116.682,288.411z"/><path d="M149.199,314.823v-2.578c-10.325,1.356-21.229,2.095-32.518,2.095c-56.25,0-103.199-18.054-114.227-42.082 C0.848,275.757,0,279.381,0,283.096v11.477c0,29.229,52.24,52.922,116.681,52.922c12.887,0,25.282-0.95,36.873-2.7 c-2.873-5.877-4.355-12.075-4.355-18.496V314.823z"/><path d="M284.92,22.379c-64.441,0-116.681,23.693-116.681,52.921v11.477c0,29.228,52.24,52.921,116.681,52.921 c64.44,0,116.681-23.693,116.681-52.921V75.3C401.601,46.072,349.36,22.379,284.92,22.379z"/><path d="M284.92,165.626c-56.25,0-103.199-18.053-114.227-42.082c-1.606,3.499-2.454,7.123-2.454,10.839v11.477 c0,29.228,52.24,52.921,116.681,52.921c64.44,0,116.681-23.693,116.681-52.921v-11.477c0-3.716-0.848-7.34-2.454-10.839 C388.119,147.573,341.17,165.626,284.92,165.626z"/><path d="M284.92,224.71c-56.25,0-103.199-18.054-114.227-42.082c-1.606,3.499-2.454,7.123-2.454,10.839v11.477 c0,29.229,52.24,52.922,116.681,52.922c64.44,0,116.681-23.693,116.681-52.922v-11.477c0-3.716-0.848-7.34-2.454-10.839 C388.119,206.657,341.17,224.71,284.92,224.71z"/><path d="M284.92,286.983c-56.25,0-103.199-18.054-114.227-42.082c-1.606,3.5-2.454,7.123-2.454,10.838v11.478 c0,29.228,52.24,52.921,116.681,52.921c64.44,0,116.681-23.693,116.681-52.921v-11.478c0-3.715-0.848-7.34-2.454-10.838 C388.119,268.928,341.17,286.983,284.92,286.983z"/><path d="M284.92,346.066c-56.25,0-103.199-18.053-114.227-42.081c-1.606,3.5-2.454,7.125-2.454,10.838V326.3 c0,29.228,52.24,52.921,116.681,52.921c64.44,0,116.681-23.693,116.681-52.921v-11.478c0-3.715-0.848-7.34-2.454-10.838 C388.119,328.012,341.17,346.066,284.92,346.066z"/></svg>`
  }
]);

const subLinks = [
  { label: "Sale", action: "Sale", isBlinking: true },
  { label: "Каталог игр Sony Турция", action: "PlayStation" },
  { label: "Каталог игр Sony Индия", action: "PlayStation" },
  { label: "Steam", action: "Servislər" },
  { label: "Spotify", action: "Servislər" },
  { label: "Chat GPT", action: "Servislər" }
];

const subscriptions = [
  { label: "Подписка PS Plus Турция", href: "#" },
  { label: "Подписка PS Plus Индия", href: "#" },
  { label: "Подписка EA Play", href: "#" },
  { label: "Подписка Ubisoft+", href: "#" },
  { label: "Подписка Spotify", href: "#" },
  { label: "Chat GPT", href: "#" }
];

const openSearch = () => {
  searchOpen.value = true;
};

const closeSearch = () => (searchOpen.value = false);
const openCart = () => (cartOpen.value = true);
const closeCart = () => (cartOpen.value = false);
const openCatalogTab = (tab) => {
  emit("select-primary", tab);
  window.scrollTo({ top: 0, behavior: "smooth" });
};

const selectPrimaryLink = (label) => emit("select-primary", label);
const goHome = () => emit("go-home");

onMounted(async () => {
  window.addEventListener("scroll", handleScroll, { passive: true });
  handleScroll();

  queryStoreRows(`SELECT * FROM store_products LIMIT 4`)
    .then((rows) => {
      cartItems.value = rows.map(mapProductRow);
    })
    .catch(() => {});

  setTimeout(() => (navReady.value = true), 100);
});

onBeforeUnmount(() => {
  window.removeEventListener("scroll", handleScroll);
});
</script>

<template>
  <header :class="['main-header', { 'is-scrolled': isScrolled }]">
    <!-- Top Row -->
    <div class="header-top">
      <div class="header-container mx-auto max-w-[1440px] px-6">
        <div class="header-inner">
          <!-- Logo -->
          <div class="brand">
            <a href="#" @click.prevent="goHome">
              <img src="/digimax_app_logo_icon.png" alt="Digimax Logo" class="brand-logo" />
            </a>
          </div>

          <!-- Desktop Navigation -->
          <nav class="desktop-nav">
            <ul class="nav-list">
              <li 
                v-for="link in primaryLinks" 
                :key="link.label"
                :class="['nav-item', { 'active': link.label === activePrimaryTab }]"
                @click="selectPrimaryLink(link.label)"
              >
                <span class="nav-icon" v-html="link.icon"></span>
                <span class="nav-label">{{ link.label }}</span>
              </li>
            </ul>
          </nav>

          <!-- Buttons -->
          <div class="header-actions">
            <button class="action-btn search-trigger" @click="openSearch">
              <img src="https://gamepropaganda.com/wp-content/uploads/2024/04/Vector-5.svg" alt="Search" />
            </button>

            <div class="subs-wrapper" @mouseenter="subMenuOpen = true" @mouseleave="subMenuOpen = false">
              <button class="subs-btn">
                Подписки
                <img src="https://gamepropaganda.com/wp-content/uploads/2025/09/Vector-11.svg" class="down-icon" />
              </button>
              <transition name="fade-slide">
                <ul v-if="subMenuOpen" class="subs-dropdown">
                  <li v-for="sub in subscriptions" :key="sub.label">
                    <a :href="sub.href">{{ sub.label }}</a>
                  </li>
                </ul>
              </transition>
            </div>

            <div class="mini-cart" @click="openCart">
              <div class="cart-trigger">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 32 32" class="cart-svg">
                  <circle cx="12.667" cy="24.667" r="2"></circle>
                  <circle cx="23.333" cy="24.667" r="2"></circle>
                  <path fill-rule="evenodd" d="M9.285 10.036a1 1 0 0 1 .776-.37h15.272a1 1 0 0 1 .99 1.142l-1.333 9.333A1 1 0 0 1 24 21H12a1 1 0 0 1-.98-.797L9.083 10.87a1 1 0 0 1 .203-.834m2.005 1.63L12.814 19h10.319l1.047-7.333z" clip-rule="evenodd"></path>
                  <path fill-rule="evenodd" d="M5.667 6.667a1 1 0 0 1 1-1h2.666a1 1 0 0 1 .984.82l.727 4a1 1 0 1 1-1.967.359l-.578-3.18H6.667a1 1 0 0 1-1-1" clip-rule="evenodd"></path>
                </svg>
                <span v-if="cartItems.length" class="cart-badge"></span>
              </div>
            </div>

            <button class="mobile-burger" @click="mobileOpen = !mobileOpen">
              <img src="https://gamepropaganda.com/wp-content/uploads/2025/09/Frame-1948756238-1.svg" />
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Subheader Row -->
    <div class="header-sub">
      <div class="header-container mx-auto max-w-[1440px] px-6">
        <div class="sub-inner">
          <a
            v-for="link in subLinks"
            :key="link.label"
            href="#"
            :class="['sub-link', { 'blinking': link.isBlinking }]"
            @click.prevent="openCatalogTab(link.action)"
          >
            {{ link.label }}
          </a>
        </div>
      </div>
    </div>

    <!-- Modals (Search, Cart - Simplified for this layout) -->
    <transition name="fade">
      <div v-if="searchOpen" class="search-modal" @click.self="closeSearch">
        <div class="search-box">
          <input v-model="searchQuery" type="text" placeholder="Search products..." autofocus />
          <button @click="closeSearch">Close</button>
        </div>
      </div>
    </transition>

    <transition name="slide-right">
      <div v-if="cartOpen" class="cart-stage" @click.self="closeCart">
        <div class="cart-drawer">
          <div class="cart-header">
            <h3>Мой заказ</h3>
            <button @click="closeCart">×</button>
          </div>
          <div class="cart-items">
            <div v-for="item in cartItems" :key="item.title" class="cart-row">
              <img :src="item.image" />
              <div>
                <p>{{ item.title }}</p>
                <strong>{{ item.price }}</strong>
              </div>
            </div>
          </div>
          <div class="cart-footer">
            <button class="checkout-btn">Checkout</button>
          </div>
        </div>
      </div>
    </transition>
  </header>
</template>

<style scoped>
.main-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: #0d0d0f;
  transition: transform 0.3s ease;
}

.header-top {
  height: 80px;
  display: flex;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08); /* Stronger divider */
  background: rgba(13, 13, 15, 0.6);
  backdrop-filter: blur(16px);
}

.header-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  width: 100%;
}

.brand {
  display: flex;
  justify-content: flex-start;
}

.brand-logo {
  height: 42px;
  width: auto;
}

.desktop-nav {
  display: flex;
  justify-content: center;
}

.nav-list {
  display: flex;
  list-style: none;
  gap: 24px;
  margin: 0;
  padding: 0;
}

.header-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 20px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  color: #a4a9b8;
  font-size: 14px;
  font-weight: 700;
  transition: all 0.2s;
}

.nav-item:hover {
  color: #fff;
}

.nav-item.active {
  color: #fff;
}

.nav-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Actions */
.action-btn {
  background: transparent;
  border: 0;
  cursor: pointer;
  display: flex;
  align-items: center;
  padding: 8px;
  border-radius: 50%;
  transition: background 0.2s;
}

.action-btn:hover {
  background: rgba(255, 255, 255, 0.05);
}

.subs-wrapper {
  position: relative;
}

.subs-btn {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 6px;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 38px;
  padding: 0 16px;
  cursor: pointer;
  transition: background 0.2s;
}

.subs-btn:hover {
  background: rgba(255, 255, 255, 0.08);
}

.subs-dropdown {
  position: absolute;
  top: 100%;
  right: 0;
  width: 240px;
  background: #14151a;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  padding: 12px 0;
  list-style: none;
  box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  margin-top: 10px;
}

.subs-dropdown li a {
  display: block;
  padding: 10px 20px;
  color: #e7e7e7;
  text-decoration: none;
  font-size: 13px;
}

.subs-dropdown li a:hover {
  background: rgba(255,255,255,0.05);
}

.cart-trigger {
  position: relative;
  cursor: pointer;
}

.cart-svg {
  width: 24px;
  height: 24px;
  color: #e7e7e7;
}

.cart-badge {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 6px;
  height: 6px;
  background: #e7e7e7;
  border-radius: 50%;
}

.mobile-burger {
  display: none;
  background: transparent;
  border: 0;
}

.header-sub {
  background: #090a0c;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
  height: 48px;
  display: flex;
  align-items: center;
}

.sub-inner {
  display: flex;
  justify-content: center;
  gap: 24px;
  width: 100%;
}

.sub-link {
  color: #8a8f9c;
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  transition: color 0.2s;
}

.sub-link:hover {
  color: #fff;
}

.sub-link.blinking {
  color: #fff;
  animation: blink 2.5s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* Modals & Drawers */
.search-modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.8);
  padding: 40px;
  display: flex;
  justify-content: center;
}

.search-box {
  width: 100%;
  max-width: 600px;
}

.search-box input {
  width: 100%;
  padding: 16px;
  background: #1a1b21;
  border: 1px solid #c3ff00;
  color: #fff;
  border-radius: 8px;
}

.cart-stage {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: flex-end;
}

.cart-drawer {
  width: 400px;
  background: #0d0d0f;
  padding: 32px;
  display: flex;
  flex-direction: column;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.cart-row {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.cart-row img {
  width: 60px;
  height: 60px;
  border-radius: 4px;
}

.checkout-btn {
  width: 100%;
  padding: 14px;
  background: #fff;
  color: #000;
  border: 0;
  border-radius: 4px;
  font-weight: 800;
  cursor: pointer;
  transition: opacity 0.2s;
}

.checkout-btn:hover {
  opacity: 0.9;
}

@media (max-width: 1024px) {
  .desktop-nav { display: none; }
  .mobile-burger { display: flex; }
}

/* Transitions */
.fade-enter-active, .fade-leave-active { transition: opacity 0.3s; }
.fade-enter-from, .fade-leave-to { opacity: 0; }

.slide-right-enter-active, .slide-right-leave-active { transition: transform 0.3s; }
.slide-right-enter-from, .slide-right-leave-to { transform: translateX(100%); }

.fade-slide-enter-active, .fade-slide-leave-active { transition: all 0.2s ease; }
.fade-slide-enter-from, .fade-slide-leave-to { opacity: 0; transform: translateY(-10px); }
</style>
