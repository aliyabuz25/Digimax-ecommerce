<script setup>
import { computed, onBeforeUnmount, onMounted, ref } from "vue";
import { mapProductRow, queryStoreRows } from "../lib/storeDb";

defineProps({
  activePrimaryTab: {
    type: String,
    default: "",
  },
});

const emit = defineEmits(["go-home", "select-primary"]);

const mobileOpen = ref(false);
const languageOpen = ref(false);
const isDarkMode = ref(false);
const cartOpen = ref(false);
const searchOpen = ref(false);
const searchQuery = ref("");
const navReady = ref(false);
const cartItems = ref([]);
const isScrolled = ref(false);

const handleScroll = () => {
  isScrolled.value = window.scrollY > 40;
};

const primaryLinks = ref([]);
const secondaryLinks = ref([]);
const languages = ref([]);
const currentLanguage = ref({ label: "AZ", name: "Azərbaycan", flag: "az" });

const fallbackSearchSuggestions = [
  "resident evil",
  "call of duty",
  "abunəlik",
  "assassin's creed",
  "stalker 2",
  "gta 5",
];

const searchSuggestions = ref(fallbackSearchSuggestions);
const searchPublishers = [
  "EA Swiss Sarl",
  "Activision Blizzard Int'l BV",
  "Sony Interactive Entertainment Europe",
  "UBISOFT ENTERTAINMENT SA",
  "WARNER BROS. INTERACTIVE",
  "CE EUROPE LIMITED",
];

const fallbackSearchResults = [
  {
    title: "Call of Duty: Modern Warfare Remastered",
    price: "585 ₼",
    image: "/digimax_1080x1080_poster_icon.png",
  },
  {
    title: "Resident Evil Requiem",
    price: "10 170 ₼",
    image: "/digimax_1080x1080_poster_icon.png",
  },
];

const searchResults = ref(fallbackSearchResults);

const icons = {
  playstation: '<svg viewBox="0 0 24 24"><path d="M10.4 3.2v9.6c0 .6-.2 1-.7 1.2l-1.8.9V5.3c0-1 .7-1.6 1.6-2.1l.9-.4Zm2.1 3.4c3 .9 5 2 5 3.3 0 1-.7 1.8-2.1 2.4l-2.9 1V9.7c0-.6-.1-1-.5-1.2-.4-.3-1-.6-1.6-.8V3.8l2.1.8Zm4.4 8.8-3.8 1.4v-1.9l2.7-1c.7-.3 1.1-.2 1.1.4v1.1Zm-10.6-.7 4.8-1.7v2L8 16.3c-1.3.5-2.6.3-3.2-.2-.8-.6-.6-1 .6-1.4Zm5.2 2.2v2l-2.7 1c-1.2.4-2.2.4-2.8.1-.7-.4-.5-.9.4-1.2l5.1-1.9Z"/></svg>',
  xbox: '<svg viewBox="0 0 24 24"><path d="M12 2.5c2.2 0 4.2.6 6 1.7-1.4.2-2.9.9-4.2 2.1-.7-.7-1.2-1-1.8-1s-1.1.3-1.8 1C8.9 5.1 7.4 4.4 6 4.2A10.9 10.9 0 0 1 12 2.5Zm-7 4.2c1.8 0 4.3 1.8 6 4.3l-4.8 8A9.5 9.5 0 0 1 5 6.7Zm14 0A9.5 9.5 0 0 1 17.8 19L13 11c1.7-2.5 4.2-4.3 6-4.3Zm-7 5.8 4.9 8c-1.4.6-3 .9-4.9.9s-3.5-.3-4.9-1l4.9-8Z"/></svg>',
  services: '<svg viewBox="0 0 24 24"><path d="M7 3h10a2 2 0 0 1 2 2v14l-3-2.1L12 19l-4-2.1L5 19V5a2 2 0 0 1 2-2Zm1 4v2h8V7H8Zm0 4v2h5v-2H8Z"/></svg>',
  coins: '<svg viewBox="0 0 24 24"><path d="M12 4c4.4 0 8 1.3 8 3s-3.6 3-8 3-8-1.3-8-3 3.6-3 8-3Zm-8 5.6c1.6 1.2 4.6 2 8 2s6.4-.8 8-2v2.8c0 1.7-3.6 3-8 3s-8-1.3-8-3V9.6Zm0 5.4c1.6 1.2 4.6 2 8 2s6.4-.8 8-2v2c0 1.7-3.6 3-8 3s-8-1.3-8-3v-2Z"/></svg>',
  search: '<svg viewBox="0 0 24 24"><path d="M10.5 4a6.5 6.5 0 1 1 0 13 6.5 6.5 0 0 1 0-13Zm0 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Zm8.9 11.5 1.6 1.6-1.4 1.4-1.6-1.6-2.4-2.4 1.4-1.4 2.4 2.4Z"/></svg>',
  cart: '<svg viewBox="0 0 24 24"><path d="M7 5h14l-1.6 8.4a2 2 0 0 1-2 1.6H10a2 2 0 0 1-2-1.5L6.2 4H3V2h4.7L8.4 6H19l.4-1Zm3 13a1.8 1.8 0 1 1 0 3.5A1.8 1.8 0 0 1 10 18Zm7 0a1.8 1.8 0 1 1 0 3.5 1.8 1.8 0 0 1 0-3.5Z"/></svg>',
  globe: '<svg viewBox="0 0 24 24"><path d="M12 3a9 9 0 1 1 0 18 9 9 0 0 1 0-18Zm5.7 8h-3a15.5 15.5 0 0 0-1.2-5A7 7 0 0 1 17.7 11Zm-5.7 8c.9 0 2.2-2.1 2.7-6H9.3c.5 3.9 1.8 6 2.7 6Zm-2.7-8h5.4c-.5-3.9-1.8-6-2.7-6s-2.2 2.1-2.7 6ZM6.5 6A15.5 15.5 0 0 0 5.3 11h3a15.5 15.5 0 0 1 1.2-5Zm-1.2 7A15.5 15.5 0 0 0 6.5 18a15.5 15.5 0 0 1 1.2-5h-3Zm8.2 5a15.5 15.5 0 0 0 1.2-5h3a7 7 0 0 1-4.2 5Z"/></svg>',
  chevron: '<svg viewBox="0 0 24 24"><path d="m7 10 5 5 5-5z"/></svg>',
  menu: '<svg viewBox="0 0 24 24"><path d="M4 7h16v2H4V7Zm0 8v-2h16v2H4Z"/></svg>',
  close: '<svg viewBox="0 0 24 24"><path d="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41Z"/></svg>',
};

const icon = (name) => icons[name] || "";
const flagUrl = (code) => `https://hatscripts.github.io/circle-flags/flags/${code}.svg`;

const activeLanguageLabel = computed(() => currentLanguage.value.label);
const normalizedQuery = computed(() => searchQuery.value.trim().toLowerCase());

const filteredSuggestions = computed(() => {
  if (!normalizedQuery.value) return [];
  return searchSuggestions.value.filter((item) => item.toLowerCase().includes(normalizedQuery.value));
});

const filteredResults = computed(() => {
  if (!normalizedQuery.value) return [];
  return searchResults.value.filter((item) => item.title.toLowerCase().includes(normalizedQuery.value));
});

const cartSubtotal = computed(() =>
  cartItems.value.reduce((sum, item) => sum + Number(item.price_current || 0), 0).toLocaleString("az-AZ"),
);

const selectLanguage = (language) => {
  currentLanguage.value = language;
  languageOpen.value = false;
};

const rowsFromStatement = (db, query) => {
  const result = db.exec(query)[0];
  if (!result) return [];
  return result.values.map((row) =>
    Object.fromEntries(result.columns.map((column, index) => [column, row[index]])),
  );
};

const loadNavigation = async () => {
  try {
    const SQL = await window.initSqlJs({
      locateFile: (file) => `https://cdnjs.cloudflare.com/ajax/libs/sql.js/1.10.3/${file}`,
    });
    const response = await fetch("/navigation.db");
    const buffer = await response.arrayBuffer();
    const db = new SQL.Database(new Uint8Array(buffer));

    primaryLinks.value = rowsFromStatement(db, "SELECT label, icon FROM nav_primary ORDER BY sort_order ASC");
    languages.value = rowsFromStatement(db, "SELECT label, name, flag, is_default FROM nav_languages ORDER BY sort_order ASC").map((item) => ({ ...item, is_default: Boolean(item.is_default) }));

    currentLanguage.value = languages.value.find((item) => item.is_default) || languages.value[0] || currentLanguage.value;
    navReady.value = true;
  } catch (err) {
    console.warn("Navigation DB load failed, using fallbacks:", err);
    primaryLinks.value = [
      { label: "PlayStation", icon: "playstation" },
      { label: "Xbox", icon: "xbox" },
      { label: "Servislər", icon: "services" },
      { label: "Oyun Valyutası", icon: "coins" },
    ];
    languages.value = [
      { label: "AZ", name: "Azərbaycan", flag: "az", is_default: true },
      { label: "RU", name: "Rus", flag: "ru", is_default: false },
      { label: "EN", name: "English", flag: "gb", is_default: false },
      { label: "TR", name: "Türkçe", flag: "tr", is_default: false },
    ];
    currentLanguage.value = languages.value[0];
    navReady.value = true;
  }
};

const applyTheme = (theme) => {
  document.body.classList.remove("theme-sweep-light", "theme-sweep-dark");
  document.body.classList.add(theme === "dark" ? "theme-sweep-dark" : "theme-sweep-light");
  document.documentElement.dataset.theme = theme;
  localStorage.setItem("digimax-theme", theme);
  isDarkMode.value = theme === "dark";
};

const toggleTheme = () => {
  applyTheme(isDarkMode.value ? "light" : "dark");
};

const openSearch = () => {
  searchOpen.value = true;
  setTimeout(() => document.querySelector(".search-field__input")?.focus(), 200);
};

const closeSearch = () => (searchOpen.value = false);
const openCart = () => (cartOpen.value = true);
const closeCart = () => (cartOpen.value = false);

const selectSuggestion = (term) => (searchQuery.value = term);
const selectPrimaryLink = (label) => emit("select-primary", label);
const goHome = () => emit("go-home");

const handleKeydown = (e) => {
  if (e.key === "Escape") {
    closeSearch();
    closeCart();
    languageOpen.value = false;
  }
};

onMounted(() => {
  const savedTheme = localStorage.getItem("digimax-theme");
  const preferredDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
  applyTheme(savedTheme || (preferredDark ? "dark" : "light"));
  loadNavigation();
  
  queryStoreRows(`SELECT * FROM store_products WHERE searchable = 1 LIMIT 12`)
    .then((rows) => {
      const products = rows.map(mapProductRow);
      searchResults.value = products;
      searchSuggestions.value = products.map((item) => item.title.toLowerCase()).slice(0, 8);
    })
    .catch(() => {});

  queryStoreRows(`SELECT * FROM store_products LIMIT 3`)
    .then((rows) => {
      cartItems.value = rows.map(mapProductRow);
    })
    .catch(() => {});

  window.addEventListener("scroll", handleScroll, { passive: true });
  handleScroll();
  window.addEventListener("keydown", handleKeydown);
});

onBeforeUnmount(() => {
  window.removeEventListener("scroll", handleScroll);
  window.removeEventListener("keydown", handleKeydown);
});
</script>

<template>
  <header :class="['premium-nav', { 'is-scrolled': isScrolled, 'mobile-on': mobileOpen }]">
    <div class="nav-shell">
      <div class="nav-container mx-auto px-6">
        <div class="nav-dock">
          <!-- Left: Brand -->
          <a href="#" class="nav-brand" @click.prevent="goHome">
            <img src="/digimax_app_logo_icon.png" alt="Digimax" />
          </a>

          <!-- Middle: Navigation Links -->
          <nav class="nav-main" :class="{ 'is-visible': navReady }">
            <div class="nav-items-wrapper">
              <a
                v-for="item in primaryLinks"
                :key="item.label"
                href="#"
                :class="['nav-item', { 'is-active': item.label === activePrimaryTab }]"
                @click.prevent="selectPrimaryLink(item.label)"
              >
                <div class="nav-item__glow"></div>
                <span class="nav-item__icon" v-html="icon(item.icon)"></span>
                <span class="nav-item__text">{{ item.label }}</span>
                <div class="nav-item__indicator"></div>
              </a>
            </div>
          </nav>

          <!-- Right: Action Buttons -->
          <div class="nav-actions">
            <!-- Mobile Toggle -->
            <button class="action-btn mobile-only" @click="mobileOpen = !mobileOpen">
              <span v-html="icon(mobileOpen ? 'close' : 'menu')"></span>
            </button>

            <!-- Desktop Search Button -->
            <button class="action-btn desktop-only" @click="openSearch" aria-label="Search">
              <div class="action-btn__icon" v-html="icon('search')"></div>
            </button>

            <!-- Language Switcher (Minimalist) -->
            <div class="language-dropdown">
              <button 
                class="lang-btn" 
                @click.stop="languageOpen = !languageOpen"
                :class="{ 'active': languageOpen }"
              >
                <img :src="flagUrl(currentLanguage.flag)" />
                <span class="desktop-only">{{ activeLanguageLabel }}</span>
              </button>
              
              <transition name="dropdown-slide">
                <div v-if="languageOpen" class="dropdown-menu">
                  <button
                    v-for="lang in languages"
                    :key="lang.label"
                    class="dropdown-item"
                    @click="selectLanguage(lang)"
                    :class="{ 'selected': lang.label === currentLanguage.label }"
                  >
                    <img :src="flagUrl(lang.flag)" />
                    <span>{{ lang.name }}</span>
                  </button>
                </div>
              </transition>
            </div>

            <!-- Theme & Cart -->
            <div class="action-group">
              <button class="action-btn theme-btn" @click="toggleTheme" title="Toggle Theme">
                <iconify-icon :icon="isDarkMode ? 'solar:moon-stars-bold' : 'solar:sun-2-bold'"></iconify-icon>
              </button>
              <button class="action-btn cart-btn" @click="openCart">
                <div class="cart-btn__count" v-if="cartItems.length">{{ cartItems.length }}</div>
                <div class="action-btn__icon" v-html="icon('cart')"></div>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Designer-Grade Search Overlay -->
    <transition name="overlay-expand">
      <div v-if="searchOpen" class="search-overlay-v2" @click.self="closeSearch">
        <div class="overlay-panel">
          <div class="search-v2__header">
            <div class="search-v2__input-box">
              <div class="search-v2__icon" v-html="icon('search')"></div>
              <input 
                v-model="searchQuery" 
                type="text" 
                placeholder="Nə axtarırsınız?"
                class="search-v2__input"
              />
              <button class="search-v2__close" @click="closeSearch" v-html="icon('close')"></button>
            </div>
          </div>

          <div class="search-v2__results-panel scroll-styled">
            <div v-if="normalizedQuery" class="results-v2__grid">
              <div v-if="!filteredResults.length" class="no-results-v2">Uyğun nəticə tapılmadı :(</div>
              <article v-for="res in filteredResults" :key="res.title" class="result-v2__card">
                <div class="result-v2__image" :style="{ backgroundImage: `url(${res.image})` }"></div>
                <div class="result-v2__content">
                  <h3>{{ res.title }}</h3>
                  <div class="result-v2__footer">
                    <span class="result-v2__price">{{ res.price }}</span>
                    <button class="result-v2__action">Bax</button>
                  </div>
                </div>
              </article>
            </div>
            <div v-else class="search-v2__welcome">
              <div class="welcome-section">
                <h4>Sizin üçün seçimlər</h4>
                <div class="welcome-tags">
                  <button v-for="tag in searchSuggestions" :key="tag" @click="selectSuggestion(tag)">
                    {{ tag }}
                  </button>
                </div>
              </div>
              <div class="welcome-section">
                <h4>Məşhur Nəşriyyatçılar</h4>
                <div class="welcome-publishers">
                  <span v-for="pub in searchPublishers" :key="pub">{{ pub }}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </transition>

    <!-- Professional Cart Sidebar -->
    <transition name="side-slide">
      <div v-if="cartOpen" class="cart-side-stage" @click.self="closeCart">
        <aside class="cart-side-panel">
          <div class="side-panel__header">
            <div>
              <h3>Səbətiniz</h3>
              <p>{{ cartItems.length }} məhsul seçilib</p>
            </div>
            <button class="side-close" @click="closeCart" v-html="icon('close')"></button>
          </div>

          <div class="side-panel__items scroll-styled">
            <div v-if="!cartItems.length" class="empty-cart-state">
              <iconify-icon icon="solar:bag-3-outline" class="empty-icon"></iconify-icon>
              <p>Səbətiniz hazıda boşdur.</p>
            </div>
            <article v-for="item in cartItems" :key="item.title" class="cart-item-v2">
              <div class="cart-item-v2__media" :style="{ backgroundImage: `url(${item.image})` }"></div>
              <div class="cart-item-v2__info">
                <strong>{{ item.title }}</strong>
                <div class="cart-item-v2__meta">
                  <span class="price">{{ item.price }}</span>
                  <button class="remove-btn">Sil</button>
                </div>
              </div>
            </article>
          </div>

          <div class="side-panel__footer" v-if="cartItems.length">
            <div class="summary-line">
              <span>Toplam</span>
              <strong>{{ cartSubtotal }} ₼</strong>
            </div>
            <button class="checkout-btn">
              Ödənişə başla
              <iconify-icon icon="solar:arrow-right-linear"></iconify-icon>
            </button>
          </div>
        </aside>
      </div>
    </transition>
  </header>
</template>

<style scoped>
/* Base Premium Styles */
.premium-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1100;
  padding: 32px 0;
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.premium-nav.is-scrolled {
  padding: 16px 0;
}

.nav-shell {
  width: 100%;
}

.nav-container {
  max-width: 1400px;
}

.nav-dock {
  background: rgba(13, 14, 18, 0.4);
  backdrop-filter: blur(32px) saturate(200%);
  -webkit-backdrop-filter: blur(32px) saturate(200%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 32px;
  height: 96px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.premium-nav.is-scrolled .nav-dock {
  height: 72px;
  border-radius: 99px;
  background: rgba(10, 11, 15, 0.75);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  max-width: fit-content;
  margin: 0 auto;
  padding: 0 24px;
}

/* Brand */
.nav-brand {
  flex-shrink: 0;
  transition: all 0.4s ease;
}

.nav-brand img {
  height: 56px;
  width: auto;
  transition: height 0.6s ease;
}

.premium-nav.is-scrolled .nav-brand img {
  height: 38px;
}

/* Main Nav Links */
.nav-main {
  flex: 1;
  display: flex;
  justify-content: center;
  opacity: 0;
  transform: translateY(12px);
  transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.nav-main.is-ready {
  opacity: 1;
  transform: translateY(0);
}

.nav-items-wrapper {
  display: flex;
  gap: 12px;
}

.nav-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 24px;
  border-radius: 99px;
  color: #9499ad;
  text-decoration: none;
  font-weight: 700;
  font-size: 14px;
  letter-spacing: -0.01em;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden;
}

.nav-item:hover {
  color: #fff;
  background: rgba(255, 255, 255, 0.05);
}

.nav-item.is-active {
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
}

.nav-item__glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.15), transparent 70%);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.nav-item:hover .nav-item__glow {
  opacity: 1;
}

.nav-item__icon {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-item__icon :deep(svg) {
  width: 100%;
  height: 100%;
  fill: currentColor;
}

.nav-item__indicator {
  position: absolute;
  bottom: 8px;
  left: 50%;
  width: 4px;
  height: 4px;
  background: #ff7e00;
  border-radius: 50%;
  transform: translateX(-50%) translateY(20px);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 0 8px #ff7e00;
}

.nav-item.is-active .nav-item__indicator {
  transform: translateX(-50%) translateY(0);
}

/* Actions Group */
.nav-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.action-btn {
  width: 52px;
  height: 52px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
}

.premium-nav.is-scrolled .action-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
}

.action-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
  transform: translateY(-2px);
}

.action-btn__icon :deep(svg) {
  width: 20px;
  height: 20px;
  fill: currentColor;
}

.action-group {
  display: flex;
  gap: 8px;
  background: rgba(0, 0, 0, 0.2);
  padding: 6px;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.premium-nav.is-scrolled .action-group {
  border: 0;
  background: transparent;
  padding: 0;
}

.cart-btn__count {
  position: absolute;
  top: -6px;
  right: -6px;
  background: #ff7e00;
  color: #000;
  font-size: 10px;
  font-weight: 900;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(255, 126, 0, 0.4);
}

/* Language Dropdown */
.language-dropdown {
  position: relative;
}

.lang-btn {
  display: flex;
  align-items: center;
  gap: 12px;
  height: 52px;
  padding: 0 20px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #fff;
  font-weight: 700;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.4s ease;
}

.premium-nav.is-scrolled .lang-btn {
  height: 44px;
  padding: 0 12px;
  border-radius: 50%;
}

.lang-btn img {
  width: 20px;
  height: 20px;
  border-radius: 50%;
}

.dropdown-menu {
  position: absolute;
  top: calc(100% + 16px);
  right: 0;
